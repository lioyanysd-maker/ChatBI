# 复制为 .env 或在系统中设置同名环境变量（勿将 .env 提交到 Git）

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chatbi
MYSQL_USERNAME=root
MYSQL_PASSWORD=your-mysql-password

# Redis（可选，未启动时查询缓存自动降级为内存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0

# 大模型（DeepSeek 或 OpenAI 兼容接口）
CHATBI_LLM_API_KEY=your-llm-api-key

# 可选：HTTP API 鉴权（前后端需一致）
CHATBI_API_KEY=

# 可选：敏感字段加密密钥（生产环境强烈建议配置）
CHATBI_ENCRYPTION_KEY=
